# Copy this file to .env and fill in the values before starting the server.
# Do NOT commit your real secrets to version control.

mongo_uri=
JWT_SECRET=
JWT_SELLER_SECRET=
PORT=4500          # can be changed if port is in use

# imagekit (optional)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL=

EMAIL_USER=         # Gmail address (use app password if 2FA enabled)
EMAIL_PASS=         # Gmail app password (no spaces)

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# The URL of the frontend that will consume the API.  Multiple values
# separated by commas are allowed for local/dev + deployed frontend.
FRONTEND_URL=http://localhost:5173
