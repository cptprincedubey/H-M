# Copy this file to .env and fill in the values before starting the server.
# Do NOT commit your real secrets to version control.

# ==================== DATABASE ====================
# MongoDB connection string
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname
mongo_uri=

# ==================== JWT SECRETS ====================
# Generate random strings using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_SELLER_SECRET=

# ==================== EMAIL CONFIGURATION ====================
# Gmail Setup Instructions:
# 1. Go to myaccount.google.com
# 2. Enable 2-Step Verification if not already enabled
# 3. Go to myaccount.google.com/apppasswords
# 4. Select Mail and your device
# 5. Copy the 16-character password (WITHOUT SPACES)
# 6. Paste it below in EMAIL_PASS
EMAIL_USER=         # Your full Gmail address (example@gmail.com)
EMAIL_PASS=         # Gmail app password - 16 characters, NO SPACES

# ==================== RAZORPAY PAYMENT ====================
# Get keys from dashboard.razorpay.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ==================== IMAGEKIT (Optional) ====================
# For image hosting. Leave empty to use local uploads folder.
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL=

# ==================== FRONTEND URL ====================
# URLs that can call this API. Separate multiple with commas.
# Examples: http://localhost:5173,https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ==================== SERVER CONFIGURATION ====================
PORT=4500          # Can be changed if port is in use
NODE_ENV=development  # Use 'production' on deployed servers

